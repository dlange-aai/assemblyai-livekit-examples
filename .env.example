# AssemblyAI — speech-to-text (all examples)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# LiveKit Cloud — required by all examples
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# LLM + TTS providers — required by the dynamic-turn-detection example.
# The including-agent-context example runs LLM and TTS through LiveKit
# Inference, so it does not need these.
ANTHROPIC_API_KEY=your_anthropic_api_key
CARTESIA_API_KEY=your_cartesia_api_key
